(sort IntToInt (UnstableFn (i64) i64))
(function f (i64) i64 :no-merge)

(primitive apply-fn (IntToInt i64) i64 (unstable-app _0 _1))
(primitive apply-direct-fn (i64) i64 (unstable-app (unstable-fn "f") _0))

(set (f 1) 9)
(let $f (unstable-fn "f"))
(check (= (apply-fn $f 1) 9))
(check (= (apply-direct-fn 1) 9))
