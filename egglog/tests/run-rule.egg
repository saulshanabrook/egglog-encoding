(datatype Expr
  (A)
  (B)
  (C)
  (Wrap Expr))

(relation Fired (Expr))

(rule ((= root (Wrap x)))
      ((Fired x))
      :name "mark-wrapped")

(let $wrapped-a (Wrap (A)))
(let $wrapped-b (Wrap (B)))
(let $a (A))

;; A failed cardinality assertion must not run either matching head.
(fail
  (run-schedule
    (run-rule "mark-wrapped" :expect 1)))
(fail (check (Fired (A))))
(fail (check (Fired (B))))

;; A partial binding can use a closed global e-class reference and selects one
;; match without creating terms.
(run-schedule
  (run-rule "mark-wrapped"
    :bind ((x $a))
    :expect 1))
(check (Fired (A)))
(fail (check (Fired (B))))

;; Omitting bindings applies all matches, and a run-rule leaf is always a full
;; query, so repeating it observes both old matches again.
(run-schedule
  (seq
    (run-rule "mark-wrapped" :expect 2)
    (run-rule "mark-wrapped" :expect 2)))
(check (Fired (A)))
(check (Fired (B)))

;; Zero matches is a successful no-op unless a different expectation is given.
(run-schedule
  (run-rule "mark-wrapped"
    :bind ((x (C)))
    :expect 0))
